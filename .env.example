# ─── API Kalitlari (1 dan 5 gacha) ───────────────────────────────────────────
# Hammasi kerak emas. Kamida 1 ta bo'lsa yetarli.
# Birinchi kalit limitga yetsa, avtomatik ikkinchisiga o'tadi va hokazo.
# 1 soatdan keyin limitga yetgan kalit qayta faollanadi.
# Haqiqiy kalitlarni .env fayliga yozing (bu faylga emas!)

GEMINI_API_KEY_1="BIRINCHI_API_KALITINGIZ"
GEMINI_API_KEY_2="IKKINCHI_API_KALITINGIZ"
GEMINI_API_KEY_3="UCHINCHI_API_KALITINGIZ"
GEMINI_API_KEY_4="TO'RTINCHI_API_KALITINGIZ"
GEMINI_API_KEY_5="BESHINCHI_API_KALITINGIZ"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
